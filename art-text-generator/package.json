{
  "name": "art-text-generator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "vite build && electron-builder"
  },
    "main": "electron/main.cjs",
    "build": {
      "appId": "com.yourname.art-text",
      "productName": "矢量艺术字生成器",
      "directories": {
        "output": "release"
      },
      "win": {
        "target": "nsis",
        "icon": "public/favicon.ico"
      },
      "nsis": {
        "oneClick": false,
        "allowToChangeInstallationDirectory": true
      },
      "files": [
        "dist/**/*",
        "electron/**/*"
      ]
    },
  "dependencies": {
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.12",
    "wait-on": "^9.0.6"
  }
}
